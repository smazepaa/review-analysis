# Example environment variables for the Apple Store Review Analysis API.
#
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
#
# `.env` is git-ignored so secrets stay local.

# ---------------------------------------------------------------------------
# Anthropic — required for the Claude-powered features (optional overall)
# ---------------------------------------------------------------------------

# Required to enable any LLM-powered feature: domain-organized insights,
# per-region domain insights, and the multilingual sentiment tiebreaker.
# Without it the API still works — those fields simply return empty / null
# and the rule-based actionable insights remain. Get a key at:
#   https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Model overrides — all optional, defaults shown
# ---------------------------------------------------------------------------

# Overall domain insights (1 call per report). Strong reasoning earns its
# keep here: scoring severity and writing recommendations across 100
# reviews × 7 domains.
# ANTHROPIC_MODEL=claude-opus-4-7

# Per-region domain insights (up to 4 calls per report). Same task on
# ~20 reviews per region — well-defined schema, less ambiguity.
# Sonnet is ~40% cheaper than Opus with the same adaptive-thinking and
# `effort` knobs.
# ANTHROPIC_REGIONAL_MODEL=claude-sonnet-4-6

# Multilingual sentiment tiebreaker (1 bulk call per report when needed).
# Three-way classification of short text in any language — no reasoning
# required. Haiku 4.5 is the right tier here.
# ANTHROPIC_SENTIMENT_MODEL=claude-haiku-4-5
